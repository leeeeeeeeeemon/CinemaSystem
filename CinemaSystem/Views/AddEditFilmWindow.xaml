<!-- Views/AddEditFilmWindow.xaml -->
<Window x:Class="CinemaSystem.Views.AddEditFilmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Добавление / Редактирование фильма"
        Height="700" 
        Width="501"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок окна -->
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                   FontSize="24" 
                   FontWeight="Medium" 
                   Margin="0,0,0,24"/>

        <!-- Форма ввода -->
        <StackPanel Grid.Row="1" Margin="0,0,0,30">
            <!-- Название фильма -->
            <TextBox x:Name="txtTitle"
                     materialDesign:HintAssist.Hint="Название фильма *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"/>

            <!-- Жанр -->
            <ComboBox x:Name="cmbGenre"
                  materialDesign:HintAssist.Hint="Жанр *"
                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                  IsEditable="False"
                  Margin="0,0,0,16"
                  DisplayMemberPath="Name" />
                
            

            <!-- Режиссёр -->
            <TextBox x:Name="txtDirector"
                     materialDesign:HintAssist.Hint="Режиссёр *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"/>

            <!-- Год выпуска -->
            <TextBox x:Name="txtReleaseYear"
                     materialDesign:HintAssist.Hint="Год выпуска * (например 2024)"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"
                     PreviewTextInput="NumberValidationTextBox"/>

            <!-- Длительность -->
            <TextBox x:Name="txtDuration"
                     materialDesign:HintAssist.Hint="Длительность (минуты) *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"
                     PreviewTextInput="NumberValidationTextBox"/>

            <!-- Анонс фильма -->
            <TextBox x:Name="txtAnnouncement"
                     materialDesign:HintAssist.Hint="Анонс фильма"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalContentAlignment="Top"
                     Height="110"
                     Margin="0,0,0,0"/>
        </StackPanel>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right">
            <Button Content="Отмена" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>

            <Button Content="Сохранить" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>