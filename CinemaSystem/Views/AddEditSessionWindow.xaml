<!-- Views/AddEditSessionWindow.xaml -->
<Window x:Class="CinemaSystem.Views.AddEditSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Добавление сеанса"
        Height="583" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                   FontSize="24" FontWeight="Medium" Margin="0,0,0,24"/>

        <StackPanel Grid.Row="1" Margin="16">
            <ComboBox x:Name="cmbFilm" Margin="10"
                      materialDesign:HintAssist.Hint="Фильм *"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="Title"/>

            <ComboBox x:Name="cmbHall" Margin="10"
                      materialDesign:HintAssist.Hint="Кинозал *"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      DisplayMemberPath="HallNumber"/>

            <DatePicker x:Name="dpDate" Margin=" 10"
                        materialDesign:HintAssist.Hint="Дата сеанса"/>

            <materialDesign:TimePicker x:Name="tpTime"  Margin="10" Is24Hours="True"
                                       materialDesign:HintAssist.Hint="Время начала"/>

            <TextBox x:Name="txtBasePrice" Margin="10"
                     materialDesign:HintAssist.Hint="Базовая цена (руб) *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>

            <Button Content="Сохранить сеанс" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>