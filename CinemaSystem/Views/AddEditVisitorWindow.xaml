<!-- Views/AddEditVisitorWindow.xaml -->
<Window x:Class="CinemaSystem.Views.AddEditVisitorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Добавление посетителя"
        Height="380" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="Новый посетитель" FontSize="22" FontWeight="Medium" Margin="0,0,0,20"/>

            <TextBox x:Name="txtFullName" 
                     materialDesign:HintAssist.Hint="ФИО *"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"/>

            <TextBox x:Name="txtPhone" 
                     materialDesign:HintAssist.Hint="Телефон"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16"/>

            <TextBox x:Name="txtBonusCard" 
                     materialDesign:HintAssist.Hint="Номер бонусной карты (необязательно)"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,24"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Отмена" 
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,12,0"
                        Click="CancelButton_Click"
                        IsCancel="True"/>

                <Button Content="Сохранить" 
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Click="SaveButton_Click"
                        IsDefault="True"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>