<!-- Views/ClientSellTicketWindow.xaml -->
<Window x:Class="CinemaSystem.Views.ClientSellTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Покупка билета"
        Height="773" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}"
        KeyDown="Window_KeyDown">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Покупка билета" FontSize="24" FontWeight="Medium" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0">

            <!-- Сеанс -->
            <GroupBox Header="Сеанс" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock x:Name="txtFilmTitle" FontSize="16" FontWeight="Medium"/>
                    <TextBlock x:Name="txtSessionInfo" Margin="0,8,0,0"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock x:Name="txtBasePrice" FontSize="14" Margin="0,8,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Данные покупателя -->
            <GroupBox Header="Ваши данные" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBox x:Name="txtFullName"
                             materialDesign:HintAssist.Hint="Ваше ФИО *"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,0,12"
                             TextChanged="txtFullName_TextChanged"/>

                    <TextBox x:Name="txtBonusCard"
                             materialDesign:HintAssist.Hint="Номер бонусной карты (если есть)"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             TextChanged="txtBonusCard_TextChanged"/>

                    <TextBlock x:Name="txtBonusInfo"
                               FontSize="13"
                               Foreground="#4CAF50"
                               Margin="0,8,0,0"
                               Visibility="Collapsed"/>
                </StackPanel>
            </GroupBox>

            <!-- Количество билетов -->
            <GroupBox Header="Количество билетов" Padding="12" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Количество:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmbQuantity"
                              Width="120"
                              SelectedIndex="0"
                              SelectionChanged="cmbQuantity_SelectionChanged"/>
                </StackPanel>
            </GroupBox>

            <!-- Расчёт -->
            <GroupBox Header="Расчёт" Padding="12">
                <StackPanel>
                    <TextBlock x:Name="txtDiscountInfo" FontSize="14"
                               Foreground="#4CAF50" Margin="0,0,0,6"/>
                    <TextBlock x:Name="txtFinalPrice" FontSize="18" FontWeight="Bold"
                               Foreground="#FF5722"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Отмена"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>

            <Button Content="Купить билеты"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#4CAF50"
                    Click="BuyButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
