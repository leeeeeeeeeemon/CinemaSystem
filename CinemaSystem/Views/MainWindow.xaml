<!-- Views/MainWindow.xaml -->
<Window x:Class="CinemaSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Автоматизированная система кинотеатра StarLight"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        KeyDown="Window_KeyDown" WindowState="Maximized">

    <materialDesign:DrawerHost>
        <!-- Боковое меню (Drawer) -->
        <materialDesign:DrawerHost.LeftDrawerContent>
            <StackPanel Width="280" Background="{DynamicResource MaterialDesignPaper}">
                <!-- Заголовок меню -->
                <materialDesign:ColorZone Mode="PrimaryMid" 
                          Padding="16"
                          materialDesign:ElevationAssist.Elevation="Dp4">
                    <TextBlock Text="STARLIGHT" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </materialDesign:ColorZone>

                <!-- Пункты меню -->
                <ListBox x:Name="MenuListBox" 
                         Margin="8" 
                         SelectionChanged="MenuListBox_SelectionChanged"
                         SelectedIndex="0">

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Filmstrip" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Фильмы" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CalendarClock" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Сеансы" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Door" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Кинозалы" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Посетители" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Ticket" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Продажа билетов" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Padding="16,12">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileDocument" Width="24" Height="24" Margin="0,0,16,0"/>
                            <TextBlock Text="Отчёты" FontSize="16" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Нижняя часть меню -->
                <StackPanel VerticalAlignment="Bottom" Margin="16">
                    <Separator/>
                    <Button Content="О программе" 
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Left"
                            Click="AboutButton_Click"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:DrawerHost.LeftDrawerContent>

        <!-- Основная рабочая область -->
        <Grid>
            <!-- Верхняя панель (AppBar) -->
            <materialDesign:ColorZone Mode="PrimaryMid" 
                                      Padding="16"
                                      materialDesign:ElevationAssist.Elevation="Dp4">
                <DockPanel Cursor="">
                    <!-- Кнопка открытия меню -->
                    <Button Style="{StaticResource MaterialDesignIconButton}"
                            Command="{x:Static materialDesign:DrawerHost.OpenDrawerCommand}"
                            CommandParameter="Left">
                        <materialDesign:PackIcon Kind="Menu" Width="52" Height="52" Foreground="White"/>
                    </Button>

                    <!-- Breadcrumbs / Текущий раздел -->
                    <TextBlock x:Name="BreadcrumbText" 
                               Margin="20,0,0,0"
                               FontSize="20" 
                               FontWeight="Medium"
                               VerticalAlignment="Center"
                               Foreground="White"/>

                    <!-- Правая часть -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="UserInfoText" 
                                   Text="Пользователь: Администратор" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,20,0"
                                   Foreground="White"/>

                        <Button Content="Выход" 
                                Style="{StaticResource MaterialDesignFlatButton}"
                                Foreground="White"
                                Click="ExitButton_Click"/>
                    </StackPanel>
                </DockPanel>
            </materialDesign:ColorZone>

            <!-- Контентная область (сюда будем подгружать страницы) -->
            <Frame x:Name="MainFrame" 
                   Margin="0,70,0,0" 
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </materialDesign:DrawerHost>
</Window>