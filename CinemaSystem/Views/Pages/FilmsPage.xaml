<!-- Views/Pages/FilmsPage.xaml -->
<Page x:Class="CinemaSystem.Views.Pages.FilmsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Фильмы"
      Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки действий -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="База фильмов" 
                       FontSize="28" 
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>

            <Button Margin="30,0,0,0" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="AddFilmButton_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,8,0"/>
                    <TextBlock Text="Добавить фильм"/>
                </StackPanel>
            </Button>

            <TextBox x:Name="SearchBox" 
                     Width="300" 
                     Margin="40,0,0,0"
                     materialDesign:HintAssist.Hint="Поиск по названию, жанру или режиссёру..."
                     TextChanged="SearchBox_TextChanged"/>
        </StackPanel>

        <!-- Табличный вид (DataGrid) -->
        <DataGrid x:Name="FilmsDataGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  IsReadOnly="False"
                  SelectionMode="Single"
                  materialDesign:DataGridAssist.CellPadding="8"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8"
                  MouseDoubleClick="FilmsDataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="250"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="120"/>
                <DataGridTextColumn Header="Режиссёр" Binding="{Binding Director.FullName}" Width="180"/>
                <DataGridTextColumn Header="Год" Binding="{Binding ReleaseYear}" Width="80"/>
                <DataGridTextColumn Header="Длительность" Binding="{Binding DurationMin}" Width="110"/>
                <DataGridTextColumn Header="Анонс" Binding="{Binding Announcement}" Width="300"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>