<!-- Views/Pages/HallsPage.xaml -->
<Page x:Class="CinemaSystem.Views.Pages.HallsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Кинозалы"
      Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="Кинозалы" 
                       FontSize="28" 
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>

            <Button Margin="30,0,0,0" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="AddHallButton_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Door" Margin="0,0,8,0"/>
                    <TextBlock Text="Добавить зал"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Таблица кинозалов -->
        <DataGrid x:Name="HallsDataGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  materialDesign:DataGridAssist.CellPadding="8"
                  MouseDoubleClick="HallsDataGrid_MouseDoubleClick">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер зала" Binding="{Binding HallNumber}" Width="120"/>
                <DataGridTextColumn Header="Вместимость" Binding="{Binding Capacity}" Width="140"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="400"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>