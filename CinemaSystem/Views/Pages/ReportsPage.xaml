<!-- Views/Pages/ReportsPage.xaml -->
<Page x:Class="CinemaSystem.Views.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Отчёты и проданные билеты"
      Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Проданные билеты" 
                   FontSize="28" 
                   FontWeight="Medium" 
                   Margin="0,0,0,20"/>

        <DataGrid x:Name="TicketsDataGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  materialDesign:DataGridAssist.CellPadding="8">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата продажи" Binding="{Binding PurchaseDate, StringFormat=dd.MM.yyyy HH:mm}" Width="160"/>
                <DataGridTextColumn Header="Фильм" Binding="{Binding Session.Film.Title}" Width="280"/>
                <DataGridTextColumn Header="Зал" Binding="{Binding Session.Hall.HallNumber}" Width="80"/>
                <DataGridTextColumn Header="Посетитель" Binding="{Binding Visitor.FullName}" Width="250"/>
                <DataGridTextColumn Header="Цена" Binding="{Binding FinalPrice, StringFormat={}{0} руб.}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>