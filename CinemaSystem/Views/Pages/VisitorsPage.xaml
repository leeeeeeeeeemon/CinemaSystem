<!-- Views/Pages/VisitorsPage.xaml -->
<Page x:Class="CinemaSystem.Views.Pages.VisitorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Title="Посетители"
      Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок и кнопки -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="База посетителей" 
                       FontSize="28" 
                       FontWeight="Medium"
                       VerticalAlignment="Center"/>

            <Button Margin="30,0,0,0" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    materialDesign:ButtonAssist.CornerRadius="8"
                    Click="AddVisitorButton_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="AccountPlus" Margin="0,0,8,0"/>
                    <TextBlock Text="Добавить посетителя"/>
                </StackPanel>
            </Button>

            <TextBox x:Name="SearchVisitorBox" 
                     Width="320" 
                     Margin="40,0,0,0"
                     materialDesign:HintAssist.Hint="Поиск по ФИО или номеру карты..."
                     TextChanged="SearchVisitorBox_TextChanged"/>
        </StackPanel>

        <!-- Таблица посетителей -->
        <DataGrid x:Name="VisitorsDataGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  MouseDoubleClick="VisitorsDataGrid_MouseDoubleClick"
                  materialDesign:DataGridAssist.CellPadding="8">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="320"/>
                <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="160"/>
                <DataGridTextColumn Header="Номер бонусной карты" Binding="{Binding BonusCardNumber}" Width="200"/>
                <DataGridTextColumn Header="Бонусные баллы" Binding="{Binding BonusPoints}" Width="140"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>