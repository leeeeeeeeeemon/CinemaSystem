<!-- Views/SellTicketWindow.xaml -->
<Window x:Class="CinemaSystem.Views.SellTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Продажа билетов"
        Height="680" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Продажа билетов" FontSize="24" FontWeight="Medium" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="16">
            <!-- Сеанс -->
            <GroupBox Header="Сеанс" Padding="12">
                <StackPanel>
                    <TextBlock x:Name="txtFilmTitle" FontSize="16" FontWeight="Medium"/>
                    <TextBlock x:Name="txtSessionInfo" Margin="0,8,0,0"/>
                </StackPanel>
            </GroupBox>

            <!-- Посетитель -->
            <GroupBox Header="Посетитель" Padding="12">
                <StackPanel>
                    <ComboBox x:Name="cmbVisitor" 
                              materialDesign:HintAssist.Hint="Выберите посетителя *"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              DisplayMemberPath="FullName"
                              SelectionChanged="cmbVisitor_SelectionChanged"/>

                    <Button Content="Создать нового посетителя" 
                            Style="{StaticResource MaterialDesignFlatButton}"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Click="CreateNewVisitor_Click"/>
                </StackPanel>
            </GroupBox>

            <!-- Количество билетов -->
            <GroupBox Header="Количество билетов" Padding="12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Количество:" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <ComboBox x:Name="cmbQuantity" 
                              Width="120"
                              SelectedIndex="0">
                        <ComboBoxItem>1</ComboBoxItem>
                        <ComboBoxItem>2</ComboBoxItem>
                        <ComboBoxItem>3</ComboBoxItem>
                        <ComboBoxItem>4</ComboBoxItem>
                        <ComboBoxItem>5</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <!-- Информация о цене и баллах -->
            <GroupBox Header="Расчёт" Padding="12">
                <StackPanel>
                    <TextBlock x:Name="txtBasePrice" FontSize="15"/>
                    <TextBlock x:Name="txtDiscountInfo" FontSize="15" Foreground="#4CAF50" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtBonusPoints" FontSize="15" Margin="0,8,0,0"/>
                    <TextBlock x:Name="txtFinalPrice" FontSize="18" FontWeight="Bold" Foreground="#FF5722" Margin="0,12,0,0"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="Отмена" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Margin="0,0,12,0"
                    Click="CancelButton_Click"
                    IsCancel="True"/>

            <Button Content="Продать билеты" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#4CAF50"
                    Click="SellButton_Click"
                    IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>