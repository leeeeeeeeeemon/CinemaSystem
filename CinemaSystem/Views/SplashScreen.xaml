<!-- Views/SplashScreen.xaml -->
<Window x:Class="CinemaSystem.Views.SplashScreen"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Кинотеатр StarLight" 
        Height="500" Width="700"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        AllowsTransparency="True"
        KeyDown="Window_KeyDown">

    <materialDesign:Card Margin="20" UniformCornerRadius="15" >
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="273*"/>
                <ColumnDefinition Width="8*"/>
                <ColumnDefinition Width="49*"/>
            </Grid.ColumnDefinitions>
            <!-- Фон с градиентом -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4A148C" Offset="0"/>
                    <GradientStop Color="#311B92" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Margin="99,0,0,0" Grid.ColumnSpan="2">

                <!-- Логотип / Название -->
                <TextBlock Text="🎬 КИНОТЕАТР" 
                           FontSize="42" 
                           FontWeight="Bold" 
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <TextBlock Text="STARLIGHT" 
                           FontSize="56" 
                           FontWeight="Black" 
                           Foreground="#FFEB3B"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Описание системы -->
                <TextBlock Text="Автоматизированная система управления кинотеатром" 
                           FontSize="18" 
                           Foreground="White" 
                           TextAlignment="Center"
                           Margin="0,0,0,40"
                           TextWrapping="Wrap"/>

                <!-- Возможности (в виде списка) -->
                <StackPanel Margin="0,0,0,30">
                    <TextBlock Text="✓ Удобное управление фильмами и сеансами" 
                               FontSize="16" Foreground="WhiteSmoke" Margin="0,4"/>
                    <TextBlock Text="✓ Продажа билетов с бонусной картой и скидками" 
                               FontSize="16" Foreground="WhiteSmoke" Margin="0,4"/>
                    <TextBlock Text="✓ Просмотр кинозалов и расписания" 
                               FontSize="16" Foreground="WhiteSmoke" Margin="0,4"/>
                    <TextBlock Text="✓ База посетителей и накопление бонусов" 
                               FontSize="16" Foreground="WhiteSmoke" Margin="0,4"/>
                </StackPanel>

                <!-- Информация об авторе -->
                <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,20,0,0" Height="218">
                    <StackPanel>
                        <TextBlock Text="Выполнил:" FontSize="14" Foreground="#B0BEC5" HorizontalAlignment="Center"/>
                        <TextBlock Text="Барышев Эмиль Евгенеьевич" 
                                   FontSize="16" FontWeight="Medium" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="Группа: 831-21" 
                                   FontSize="14" Foreground="#B0BEC5" HorizontalAlignment="Center"/>
                        <TextBlock Text="2026 год" 
                                   FontSize="13" Foreground="#90A4AE" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>

            <!-- Подсказка внизу -->
            <TextBlock Text="Нажмите ESC для продолжения" 
                       VerticalAlignment="Top" 
                       HorizontalAlignment="Left"
                       Margin="228,296,0,0"
                       Foreground="#B0BEC5"
                       FontSize="14"/>
        </Grid>
    </materialDesign:Card>
</Window>